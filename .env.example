APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL pública del API sin path interno: si el virtual host apunta a /public de Laravel, la URL
# NO debe terminar en /public (ej. https://api-admin.tudominio.com). Si el hosting obliga
# /public en la URL, el admin-spa debe usar la misma base en VITE_API_URL (.../public/api/admin).
APP_URL=http://localhost

# Orígenes del SPA (header Origin), separados por coma. Preferí siempre esquema + host:
# https://admin.tudominio.com — también se acepta solo el host y se asume https://.
# Evitá entradas sueltas tipo "comerciocity.com" si el panel no se abre desde ese origen.
# Vacío → CORS usa *. Tras cambiar: php artisan config:clear (o config:cache).
ADMIN_SPA_URL=http://localhost:8002

LOG_CHANNEL=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
# Minutos de inactividad de sesión web (~10 años). Solo afecta rutas con cookie de sesión.
SESSION_LIFETIME=5256000
# Minutos de validez del token Bearer del admin-spa. Dejar vacío = sin vencimiento (logout manual).
# SANCTUM_EXPIRATION=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
# PUSHER_GUZZLE_VERIFY_SSL=false
# PUSHER_GUZZLE_CA_BUNDLE="C:/path/cacert.pem"

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# -----------------------------------------------------------------------------
# ComercioCity — Mail 1 - DEMO (LeadDemoMail en config/commerciocity.php → demo_mail)
# -----------------------------------------------------------------------------
# Contraseña que se muestra en el mail (la demo suele usar la misma para todos los leads).
COMMERCIOCITY_DEMO_PASSWORD=demo1234
# Link wa.me / api.whatsapp.com del equipo comercial.
COMMERCIOCITY_DEMO_WHATSAPP_URL=https://api.whatsapp.com/send?phone=
# Firma del pie del correo.
COMMERCIOCITY_DEMO_PRESENTER_NAME="Equipo ComercioCity"
COMMERCIOCITY_DEMO_PRESENTER_ROLE=Fundador
# URLs de videos (vacío = esa sección no se muestra en el HTML del mail).
COMMERCIOCITY_DEMO_VIDEO_INTRO=
COMMERCIOCITY_DEMO_VIDEO_STOCK=
COMMERCIOCITY_DEMO_VIDEO_VENTAS=
COMMERCIOCITY_DEMO_VIDEO_ECOMMERCE=
COMMERCIOCITY_DEMO_VIDEO_CIERRE=

# Protocolo de WhatsApp para Claude (repo privado en GitHub).
GITHUB_PROTOCOL_TOKEN=
PROTOCOL_CACHE_TTL_MINUTES=10

# Anthropic (Claude) — sugerencias de conversación en leads (admin-spa).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Opcional: ruta a cacert.pem (https://curl.se/ca/cacert.pem) para evitar cURL error 60 en Windows/WAMP.
#ANTHROPIC_CAINFO=C:/wamp64/certs/cacert.pem
# Solo entorno local sin CA en php.ini: false (no usar en producción).
#ANTHROPIC_VERIFY_SSL=false

# Kapso (envío WhatsApp saliente). Si no se definen, heredan ANTHROPIC_CAINFO / ANTHROPIC_VERIFY_SSL.
#KAPSO_CAINFO=C:/wamp64/certs/cacert.pem
#KAPSO_VERIFY_SSL=false

# -----------------------------------------------------------------------------
# Credenciales SSH para deployments (ClientSshCredentialSeeder / DeploymentService)
# -----------------------------------------------------------------------------
#SSH_SHARED_HOSTING_HOST=
#SSH_SHARED_HOSTING_PORT=22
#SSH_SHARED_HOSTING_USERNAME=
#SSH_SHARED_HOSTING_PASSWORD=
#SSH_VPS_HOST=
#SSH_VPS_PORT=22
#SSH_VPS_USERNAME=
#SSH_VPS_PASSWORD=

# Deployment (VPS de builds). Si npm falla: conectate por SSH (mismo usuario que client_ssh_credentials vps)
# y ejecutá: bash -lic 'which npm && npm -v'. Copiá la ruta en DEPLOY_NPM_BIN.
#DEPLOY_BUILDS_SPA_PATH=/home/builds/empresa-spa
#DEPLOY_BUILDS_API_PATH=/home/builds/empresa-api
#DEPLOY_VPS_USE_INTERACTIVE_LOGIN_SHELL=true
#DEPLOY_VPS_USE_LOGIN_SHELL_ONLY=false
#DEPLOY_BUILD_SHELL_PREAMBLE=source ~/.nvm/nvm.sh
#DEPLOY_NPM_BIN=/root/.nvm/versions/node/v20.20.2/bin/npm
#DEPLOY_NVM_DIR=/root/.nvm
# Webpack 4 + Node 20 en VPS Linux (package.json del SPA usa "set" solo en Windows).
#DEPLOY_NODE_OPTIONS=--openssl-legacy-provider
#DEPLOY_SPA_PUSHER_KEY=98f389f62ef4a392fc77
#DEPLOY_SPA_PUSHER_CLUSTER=sa1
#DEPLOY_SPA_IDIOM=en
#DEPLOY_SPA_APP_NAME=ComercioCity
#DEPLOY_SPA_ROUTE_INDEX=article
#DEPLOY_SPA_ROUTE_TO_REDIRECT_IF_UNAUTHENTICATED=login
#DEPLOY_SPA_IMAGE_URL_PROP_NAME=hosting_url
#DEPLOY_SPA_CUSTOM_CONFIGURATION_PAGE=true
#DEPLOY_SPA_USE_HOME_PAGE=true
#DEPLOY_SPA_USE_HELP_DROPDOWN=true
#DEPLOY_SPA_HAS_EXTRA_CONFIG=true
#DEPLOY_SPA_ATTEMPT_PROP=doc_number
#DEPLOY_SPA_ATTEMPT_TEXT="numero de documento"
# SSH_VPS_USERNAME en client_ssh_credentials debe ser el mismo usuario (ej. root).
#DEPLOY_COMPOSER_BIN=composer

# Google Calendar OAuth2 - Credenciales creadas en Google Cloud Console
# (tipo Web application, scope calendar.readonly)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://admin-api.comerciocity.com/api/admin/calendar/google/callback

# Web Push (VAPID) - Claves para firmar notificaciones push a devices de admins.
# Generar con: php -r 'require "vendor/autoload.php"; print_r(Minishlink\WebPush\VAPID::createVapidKeys());'
# La private key NUNCA se commitea; cargar el par real en el .env de cada entorno.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@comerciocity.com
